# Drupal 11 CI/CD 环境变量配置
# 复制并修改此文件为 .env.ci
# ⚠️  不要将此文件提交到 Git!

# ────────────────────────────────────────────────
# 服务器连接配置
# ────────────────────────────────────────────────

# 开发环境
DEV_SERVER=dev.example.com
DEV_USER=www-data
DEV_PATH=/var/www/html
DEV_SSH_KEY=~/.ssh/id_rsa_dev

# 预发环境
STAGING_SERVER=staging.example.com
STAGING_USER=www-data
STAGING_PATH=/var/www/html
STAGING_SSH_KEY=~/.ssh/id_rsa_staging

# 生产环境
PROD_SERVER=www.example.com
PROD_USER=www-data
PROD_PATH=/var/www/html
PROD_SSH_KEY=~/.ssh/id_rsa_prod

# ────────────────────────────────────────────────
# 数据库配置
# ────────────────────────────────────────────────

# CI 环境
CI_DB_HOST=mysql
CI_DB_PORT=3306
CI_DB_NAME=drupal_ci
CI_DB_USER=drupal_user
CI_DB_PASSWORD=drupal_pass

# 生产数据库
PROD_DB_HOST=localhost
PROD_DB_NAME=drupal_prod
PROD_DB_USER=drupal_prod_user
PROD_DB_PASSWORD=(需要设置强密码)
PROD_DB_SSL=required

# ────────────────────────────────────────────────
# Composer 配置
# ────────────────────────────────────────────────

# GitHub OAuth Token（私有模块）
COMPOSER_GITHUB_OAUTH_TOKEN=(从 https://github.com/settings/tokens 获取)

# ────────────────────────────────────────────────
# Drupal 配置
# ────────────────────────────────────────────────

DRUPAL_ENV=dev
DRUPAL_SITE_NAME="Drupal CI"
DRUPAL_SITE_MAIL=noreply@example.com

# ────────────────────────────────────────────────
# 部署配置
# ────────────────────────────────────────────────

MAX_RETRIES=3
DEPLOY_TIMEOUT=900  # 15 分钟
DRUSH_MEMORY_LIMIT=512M
DRUSH_PHP=/usr/bin/php8.2

# ────────────────────────────────────────────────
# 通知配置（可选）
# ────────────────────────────────────────────────

# Slack
SLACK_WEBHOOK_URL=(Slack webhook URL)

# Telegram
TG_BOT_TOKEN=(Telegram bot token)
TG_CHAT_ID=(Telegram chat ID)

# ────────────────────────────────────────────────
# 安全提示
# ────────────────────────────────────────────────
# 1. 不要将此文件提交到 Git
# 2. 使用 GitLab/GitHub 的加密变量
# 3. 定期轮换密钥
# 4. 使用强密码
